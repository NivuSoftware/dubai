# macOS
.DS_Store

# Variables de entorno — nunca subir al repo
.env
.env.*
backend/.env
backend/.env.*
!.env.example
!backend/.env.example

# Python cache / compiled files
__pycache__/
*.py[cod]

# Backend generated uploads
backend/anuncios/
backend/modelos/
backend/verification_requests/

# Keep placeholder files if needed
!backend/anuncios/.gitkeep
!backend/modelos/.gitkeep
!backend/verification_requests/.gitkeep
